{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@careertwin/*": ["../packages/*/src"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "apps/*/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "apps/web"]
}
